{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "write_file|edit_file|create_file",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\"",
            "timeout": 10000,
            "description": "Auto-format files after Claude Code edits them"
          }
        ]
      }
    ]
  }
}
